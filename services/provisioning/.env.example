# Server
PORT=3100

# Supabase (use service_role key — bypasses RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin API Key (generate a random string)
ADMIN_API_KEY=your-random-admin-key

# Docker
DOCKER_SOCKET=/var/run/docker.sock
AGENT_IMAGE=hana-agent:latest
AGENT_NETWORK=hana-network

# Skills
SKILLS_PATH=/opt/hana/skills

# Anthropic (passed to agent containers)
ANTHROPIC_API_KEY=sk-ant-...

# Compliance Scheduler (cron: 1st of each month at 01:00)
CRON_COMPLIANCE=0 1 1 * *
